# Production environment secrets
# Copy to .prod.env and fill in values
# Usage: podman compose --env-file .prod.env up -d
#
# Global API keys (CLAUDE_CODE_OAUTH_TOKEN, GOOGLE_API_KEY, etc.) flow through
# from host environment automatically if already set (e.g., via ~/.bashrc).
# Only add entries here for keys NOT in your OS environment.

CLAUDE_CODE_OAUTH_TOKEN=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=

# Database connection (includes password)
PRISM_DATABASE_URL=postgresql+asyncpg://prism:<password>@postgres:5432/prism

# Path to postgres password file for Docker secrets
POSTGRES_PASSWORD_FILE=~/.config/prism/postgres_password

# Optional: path to custom config override YAML
# PRISM_OVERRIDE_CONFIG=./config-custom/config.prod.yaml
