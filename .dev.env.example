# Dev environment secrets
# Copy to .dev.env and fill in values
# Usage: podman compose --env-file .dev.env -f docker-compose.dev.yaml up -d
#
# Global API keys (CLAUDE_CODE_OAUTH_TOKEN, GOOGLE_API_KEY, etc.) flow through
# from host environment automatically if already set (e.g., via ~/.bashrc).
# Only add entries here for keys NOT in your OS environment.

CLAUDE_CODE_OAUTH_TOKEN=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
TAVILY_API_KEY=
