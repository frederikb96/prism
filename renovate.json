{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Europe/Berlin",
  "schedule": ["* * * * 6"],
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "branchConcurrentLimit": 0,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "labels": ["dependencies", "renovate"],
  "packageRules": [
    {
      "description": "Patch updates: no delay",
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Minor updates: 14-day stability window",
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Major updates: 30-day stability window",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "30 days"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Claude Code CLI version in Dockerfile",
      "managerFilePatterns": ["/^docker/Dockerfile$/"],
      "matchStrings": ["@anthropic-ai/claude-code@(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@anthropic-ai/claude-code"
    }
  ]
}
